{
  "name": "@ai-video-assembly/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "pnpm run build:main && pnpm run build:worker && pnpm run build:preload && pnpm run build:renderer",
    "build:main": "tsc6 -p tsconfig.main.json",
    "build:worker": "tsc6 -p tsconfig.worker.json",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "typecheck": "tsc6 --noEmit -p tsconfig.main.json && tsc6 --noEmit -p tsconfig.worker.json && tsc6 --noEmit -p tsconfig.preload.json && tsc6 --noEmit -p tsconfig.renderer.json"
  },
  "dependencies": {
    "@ai-video-assembly/domain": "workspace:*",
    "@ai-video-assembly/media": "workspace:*",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.2.0",
    "vite": "8.1.5"
  }
}
